# .env.example — monorepo root
# Copy to .env and fill in values. Never commit .env.
# Each service also accepts its own .env file — this file documents the full picture.

# ── Django backend ──────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=                          # generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=api.yourdomain.com,backend
CORS_ALLOWED_ORIGINS=https://yourdomain.com
DATABASE_URL=postgres://career_mentor:CHANGE_ME@postgres:5432/career_mentor
REDIS_URL=redis://redis:6379/0
AI_SERVICE_URL=http://ai_service:8001
AI_SERVICE_SHARED_SECRET=            # generate: openssl rand -hex 32
JWT_ACCESS_TOKEN_LIFETIME_MIN=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
DJANGO_ALLOW_ASYNC_UNSAFE=true  # required for SSE StreamingHttpResponse
FRONTEND_URL=https://yourdomain.com
PASSWORD_RESET_TIMEOUT_SECONDS=3600
SENTRY_DSN=                          # optional; leave blank to disable
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=                 # SendGrid / Resend / Mailgun API key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── FastAPI AI service ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=                      # from Google AI Studio — keep billing DISABLED on this project
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_RPM_LIMIT=15
# DATABASE_URL same as Django (shared Postgres instance)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3001   # self-hosted; or https://cloud.langfuse.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=               # server-side only — never sent to browser
LOG_LEVEL=INFO

# ── Cloudinary (shared by backend and frontend) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=               # server-side only — never expose to browser
CLOUDINARY_UPLOAD_PRESET=            # unsigned preset: pdf/docx only, max 5 MB
CLOUDINARY_AVATAR_PRESET=            # unsigned preset: images only, max 2 MB

# ── React frontend (build-time only, these are safe to expose) ─────────────────
VITE_API_BASE_URL=https://api.yourdomain.com/api/v1
VITE_CLOUDINARY_CLOUD_NAME=          # same as CLOUDINARY_CLOUD_NAME above
VITE_CLOUDINARY_UPLOAD_PRESET=       # same as CLOUDINARY_UPLOAD_PRESET above
VITE_CLOUDINARY_AVATAR_PRESET=       # same as CLOUDINARY_AVATAR_PRESET above
VITE_SENTRY_DSN=                     # optional; leave blank to disable

# ── CI/CD (GitHub Actions secrets — set in Settings → Secrets and variables → Actions) ──
# STAGING_API_BASE_URL
# GOOGLE_API_KEY_GOLDEN       separate free-tier key for nightly golden tests only
# CLOUDINARY_CLOUD_NAME
# CLOUDINARY_UPLOAD_PRESET
# CLOUDINARY_API_KEY
# CLOUDINARY_API_SECRET
# LANGFUSE_PUBLIC_KEY
# LANGFUSE_SECRET_KEY
# LANGFUSE_HOST
# AI_SERVICE_SHARED_SECRET
# REGISTRY                    e.g. ghcr.io/yourorg
